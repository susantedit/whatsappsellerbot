# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Firebase (used by PHP and admin panel)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# SMTP (used by bot for order email notifications)
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
NOTIFY_EMAIL=your@gmail.com

# Firebase Realtime Database URL (used by bot)
FIREBASE_URL=https://your-project-default-rtdb.firebaseio.com

# App environment: "production" or "development"
APP_ENV=production

# Admin panel gate (HTTP Basic Auth)
ADMIN_GATE_USER=admin
ADMIN_GATE_PASS=

# Gemini AI key — get from https://aistudio.google.com
GEMINI_API_KEY=

# 2FA TOTP secret — generate at https://totp.danhersam.com
# Then add to Google Authenticator / Authy manually
TOTP_SECRET=

# eSewa Payment Gateway (optional for payment verification)
ESEWA_MERCHANT_CODE=
ESEWA_MERCHANT_SECRET=
ESEWA_API_URL=https://eSewa.com.np
