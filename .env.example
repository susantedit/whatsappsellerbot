# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Firebase (used by PHP and admin panel)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# SMTP (used by index.php for OTP emails)
SMTP_USER=
SMTP_PASS=

# App environment: "production" or "development"
APP_ENV=production

# Admin panel gate (HTTP Basic Auth — blocks URL access before login page)
ADMIN_GATE_USER=admin
ADMIN_GATE_PASS=

# 2FA TOTP secret — generate at https://totp.danhersam.com
# Or run: python3 -c "import base64,os; print(base64.b32encode(os.urandom(20)).decode())"
# Then add the secret to Google Authenticator / Authy manually
GEMINI_API_KEY=AIzaSyBH58S4_nMbzdOTX-eMzvaT-tR4OE_zC2Q

TOTP_SECRET=
ADMIN_GATE_PASS=

# App environment: "production" or "development"
APP_ENV=production
